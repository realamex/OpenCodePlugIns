#!/bin/bash
# bin/oc-restore — 恢复 cmux 中的 OpenCode 会话
#
# 用法: oc-restore
#   读取 state file，按 workspaceId 分组，为每组创建 cmux workspace 并启动 opencode
#   恢复完成后轮询 oc-scan 直到所有会话都被重新捕获

set -euo pipefail

# ── 路径（解析符号链接） ──
SELF="$0"
[ -L "$SELF" ] && SELF="$(readlink "$SELF")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$PROJECT_DIR/lib/state.sh"

OC_SCAN="$PROJECT_DIR/bin/oc-scan"

# ── 颜色 ──
C_RED='\033[0;31m'
C_GREEN='\033[0;32m'
C_YELLOW='\033[1;33m'
C_CYAN='\033[0;36m'
C_BOLD='\033[1m'
C_DIM='\033[2m'
C_RESET='\033[0m'
C_ITEM='\033[0;36m'

# ── 检查 state file ──
if [ ! -f "$STATE_FILE" ] || [ "$(jq 'keys | length' "$STATE_FILE" 2>/dev/null)" = "0" ]; then
  echo "No sessions to restore."
  exit 0
fi

# ── 过滤掉 sessionId 为空的记录，按 workspaceId 分组 → 临时文件 ──
GROUPS_FILE=$(mktemp "${STATE_DIR}/groups.tmp.XXXXXX")
trap "rm -f '$GROUPS_FILE'" EXIT

jq '
  to_entries
  | map(select(.value.sessionId != "" and .value.sessionId != null))
  | group_by(.value.workspaceId)
  | map({
      workspaceId: .[0].value.workspaceId,
      surfaces: map({
        surfaceId: .key,
        sessionId: .value.sessionId,
        cwd: .value.cwd
      })
    })
' "$STATE_FILE" > "$GROUPS_FILE"

GROUP_COUNT=$(jq 'length' "$GROUPS_FILE")

if [ "$GROUP_COUNT" = "0" ]; then
  echo "No sessions to restore (all records have empty sessionId)."
  exit 0
fi

# ── 统计 ──
TOTAL_SESSIONS=$(jq '[.[].surfaces | length] | add' "$GROUPS_FILE")
echo -e "Restoring ${C_BOLD}$TOTAL_SESSIONS${C_RESET} session(s) across $GROUP_COUNT workspace(s)..."

# ── 逐组恢复 ──
for i in $(seq 0 $(( GROUP_COUNT - 1 ))); do
  SURFACE_COUNT=$(jq -r ".[$i].surfaces | length" "$GROUPS_FILE")

  # 第一个 surface 的信息——用于创建 workspace
  FIRST_SESSION_ID=$(jq -r ".[$i].surfaces[0].sessionId" "$GROUPS_FILE")
  FIRST_CWD=$(jq -r ".[$i].surfaces[0].cwd" "$GROUPS_FILE")
  OC_CMD="opencode --session $FIRST_SESSION_ID"

  # 创建 workspace 并直接启动 opencode
  WS_OUTPUT=$(cmux new-workspace --cwd "$FIRST_CWD" --command "$OC_CMD" 2>&1 || true)
  sleep 1
  WS_REF=$(echo "$WS_OUTPUT" | grep -o 'workspace:[0-9]*' | head -1)

  if [ -z "$WS_REF" ]; then
    echo "  Warning: failed to create workspace for group $i, skipping."
    continue
  fi

  echo -e "  ${C_ITEM}[$WS_REF]${C_RESET} opencode --session $FIRST_SESSION_ID"

  # 同 workspace 多个 surface → 分屏
  if [ "$SURFACE_COUNT" -le 1 ]; then continue; fi
  for j in $(seq 1 $(( SURFACE_COUNT - 1 ))); do
    SESSION_ID=$(jq -r ".[$i].surfaces[$j].sessionId" "$GROUPS_FILE")
    CWD=$(jq -r ".[$i].surfaces[$j].cwd" "$GROUPS_FILE")

    cmux new-split right --workspace "$WS_REF" 2>&1 || true
    sleep 1

    OC_CMD="cd $CWD && opencode --session $SESSION_ID"
    cmux send --workspace "$WS_REF" "$OC_CMD
" 2>/dev/null || true

    echo -e "  ${C_ITEM}[$WS_REF split]${C_RESET} opencode --session $SESSION_ID"
  done
done

echo ""
echo -e "${C_GREEN}${C_BOLD}Restored $TOTAL_SESSIONS session(s).${C_RESET}"
echo ""
echo -e "${C_RED}${C_BOLD}================================================${C_RESET}"
echo -e "${C_RED}${C_BOLD}  DO NOT close this window.${C_RESET}"
echo -e "${C_YELLOW}  Waiting for all sessions to finish loading...${C_RESET}"
echo -e "${C_RED}${C_BOLD}================================================${C_RESET}"
echo ""

# ── 轮询 scan 直到全部会话被捕获 ──
POLL_INTERVAL="${OC_RESTORE_POLL_INTERVAL:-1}"
POLL_MAX="${OC_RESTORE_POLL_MAX:-30}"

if [ "$POLL_MAX" -le 0 ] 2>/dev/null; then
  "$OC_SCAN" --quiet 2>/dev/null || oc-scan --quiet 2>/dev/null || true
else
  for attempt in $(seq 1 "$POLL_MAX"); do
    REMAINING_S=$(( (POLL_MAX - attempt + 1) * POLL_INTERVAL ))
    printf "  ${C_YELLOW}[%d/%d]${C_RESET} ${C_DIM}Scanning... timeout in ~%ds${C_RESET}\r" "$attempt" "$POLL_MAX" "$REMAINING_S"
    sleep "$POLL_INTERVAL"
    "$OC_SCAN" --quiet 2>/dev/null || oc-scan --quiet 2>/dev/null || true

    CAPTURED=$(jq 'keys | length' "$STATE_FILE" 2>/dev/null || echo "0")
    printf "\033[2K"
    if [ "$CAPTURED" -ge "$TOTAL_SESSIONS" ]; then
      echo -e "  ${C_GREEN}[${attempt}/${POLL_MAX}] Captured ${CAPTURED}/${TOTAL_SESSIONS} session(s)${C_RESET}"
      break
    else
      echo -e "  ${C_YELLOW}[${attempt}/${POLL_MAX}]${C_RESET} Captured ${CAPTURED}/${TOTAL_SESSIONS} ${C_DIM}(waiting...)${C_RESET}"
    fi
  done

  echo ""
  FINAL=$(jq 'keys | length' "$STATE_FILE" 2>/dev/null || echo "0")
  if [ "$FINAL" -ge "$TOTAL_SESSIONS" ]; then
    echo -e "${C_GREEN}${C_BOLD}All $FINAL session(s) captured.${C_RESET}"
  else
    echo -e "${C_RED}Warning: captured $FINAL/$TOTAL_SESSIONS.${C_RESET} Some sessions may still be loading."
    echo -e "Run ${C_CYAN}Cmd+P > 'Scan'${C_RESET} later to refresh."
  fi
fi

echo ""
echo -e "${C_DIM}Done. This window can be closed.${C_RESET}"
