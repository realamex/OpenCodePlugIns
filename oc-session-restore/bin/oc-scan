#!/bin/bash
# bin/oc-scan — 全量快照当前 cmux 中所有 OpenCode 会话，原子写入 state file
#
# 用法: oc-scan [--quiet]
#
# 防重复：取消旧 scan 进程，确保只有最后一次 scan 的数据写入
# 原子写入：先写 tmp 文件，全部就绪后 mv 到 state.json

set -euo pipefail

# ── 路径（解析符号链接） ──
SELF="$0"
[ -L "$SELF" ] && SELF="$(readlink "$SELF")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$PROJECT_DIR/lib/state.sh"

QUIET=""
[ "${1:-}" = "--quiet" ] && QUIET=1

C_GREEN='\033[0;32m'
C_YELLOW='\033[1;33m'
C_RED='\033[0;31m'
C_DIM='\033[2m'
C_RESET='\033[0m'

log()  { [ -z "$QUIET" ] && echo -e "$@" || true; }

# ── 1. 防重复：kill 旧 scan，写入自己的 PID ──
mkdir -p "$STATE_DIR"
if [ -f "$SCAN_PID_FILE" ]; then
  old_pid=$(cat "$SCAN_PID_FILE" 2>/dev/null)
  if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
    kill "$old_pid" 2>/dev/null || true
    # 等旧进程退出（最多 1 秒）
    for _ in $(seq 1 10); do
      kill -0 "$old_pid" 2>/dev/null || break
      sleep 0.1
    done
  fi
fi
echo $$ > "$SCAN_PID_FILE"

# 清理函数：退出时删除 PID 文件和残留 tmp 目录
cleanup() {
  rm -f "$SCAN_PID_FILE" 2>/dev/null
  rm -rf "$STATE_DIR"/scan.tmp.* 2>/dev/null
}
trap cleanup EXIT

# ── 2. 获取 cmux tree ──
TREE_JSON=$(cmux tree --json --all 2>/dev/null) || { log "Error: cmux tree failed."; exit 1; }

TMPDIR_SCAN=$(mktemp -d "${STATE_DIR}/scan.tmp.XXXXXX")

# 提取所有 "OC | xxx" workspace
echo "$TREE_JSON" | jq -r '
  [
    .windows[].workspaces[] |
    select(.title | startswith("OC | ")) |
    .ref as $ws_ref | .title as $ws_title |
    .panes[].surfaces[] |
    select(.type == "terminal" and .tty != null) |
    {
      ws_ref: $ws_ref,
      ws_title: $ws_title,
      ws_session_title: ($ws_title | ltrimstr("OC | ")),
      tty: .tty
    }
  ]
' > "$TMPDIR_SCAN/surfaces.json"

SURFACE_COUNT=$(jq 'length' "$TMPDIR_SCAN/surfaces.json")
if [ "$SURFACE_COUNT" = "0" ]; then
  log "No OpenCode workspaces found in cmux."
  # 写入空 state（覆盖旧数据）
  echo '{}' > "$TMPDIR_SCAN/result.json"
  mv "$TMPDIR_SCAN/result.json" "$STATE_FILE"
  exit 0
fi

log "Found ${C_YELLOW}$SURFACE_COUNT${C_RESET} OpenCode surface(s) in cmux. Scanning..."

# ── 3. 获取 opencode 进程 → tty → env 映射 ──
PID_MAP="[]"
for pid in $(ps -eo pid=,comm= | grep ' opencode$' | awk '{print $1}'); do
  tty=$(ps -o tty= -p "$pid" 2>/dev/null | xargs)
  [ -z "$tty" ] && continue
  env_data=$(ps eww -o args= -p "$pid" 2>/dev/null || true)
  surface=$(echo "$env_data" | tr ' ' '\n' | grep '^CMUX_SURFACE_ID=' | head -1 | cut -d= -f2)
  workspace=$(echo "$env_data" | tr ' ' '\n' | grep '^CMUX_WORKSPACE_ID=' | head -1 | cut -d= -f2)
  cwd=$(lsof -p "$pid" -a -d cwd -Fn 2>/dev/null | grep '^n' | head -1 | cut -c2- || echo "$HOME")
  [ -z "$surface" ] && continue
  PID_MAP=$(echo "$PID_MAP" | jq \
    --arg tty "$tty" --arg s "$surface" --arg w "$workspace" --arg c "$cwd" \
    '. + [{tty: $tty, surface: $s, workspace: $w, cwd: $c}]')
done
echo "$PID_MAP" > "$TMPDIR_SCAN/pid_map.json"

# ── 4. 获取 opencode session list ──
opencode session list -n 200 --format json > "$TMPDIR_SCAN/sessions.json" 2>/dev/null || { log "Error: opencode session list failed."; exit 1; }

# ── 辅助函数 ──
match_session_exact() {
  local title="$1"
  [ -z "$title" ] && return
  jq -r --arg t "$title" \
    '[.[] | select(.title == $t)] | sort_by(.updated) | last | .id // empty' \
    "$TMPDIR_SCAN/sessions.json"
}

match_session_fuzzy() {
  local title="$1"
  [ -z "$title" ] && return
  jq -r --arg t "$title" \
    '[.[] | select((.title | contains($t)) or ($t | contains(.title)))] | sort_by(.updated) | last | .id // empty' \
    "$TMPDIR_SCAN/sessions.json"
}

extract_screen_title() {
  local ws_ref="$1"
  local screen
  screen=$(cmux read-screen --workspace "$ws_ref" 2>/dev/null) || return

  local ctx_line
  ctx_line=$(echo "$screen" | grep 'Context' | head -1)
  [ -z "$ctx_line" ] && return
  local ctx_col
  ctx_col=$(echo "$ctx_line" | sed 's/Context.*//' | wc -c | xargs)
  local start_col=$((ctx_col - 30))
  [ "$start_col" -lt 100 ] && start_col=100

  local line2
  line2=$(echo "$screen" | sed -n '2p' | cut -c${start_col}- | xargs)

  local sid
  sid=$(match_session_exact "$line2")
  if [ -n "$sid" ]; then
    echo "$line2"
    return
  fi

  local line3
  line3=$(echo "$screen" | sed -n '3p' | cut -c${start_col}- | xargs)
  if [ -n "$line3" ] && [ "$line3" != "Context" ]; then
    local combined="$line2 $line3"
    sid=$(match_session_exact "$combined")
    if [ -n "$sid" ]; then
      echo "$combined"
      return
    fi
  fi

  echo "$line2"
}

# ── 5. 逐个 workspace 扫描，构建结果 JSON ──
RESULT="{}"
FOUND=0
SKIPPED=0

for i in $(seq 0 $(( SURFACE_COUNT - 1 ))); do
  WS_REF=$(jq -r ".[$i].ws_ref" "$TMPDIR_SCAN/surfaces.json")
  WS_TITLE=$(jq -r ".[$i].ws_title" "$TMPDIR_SCAN/surfaces.json")
  WS_SESSION_TITLE=$(jq -r ".[$i].ws_session_title" "$TMPDIR_SCAN/surfaces.json")
  TTY=$(jq -r ".[$i].tty" "$TMPDIR_SCAN/surfaces.json")

  # tty → CMUX env
  MATCH=$(jq -r --arg tty "$TTY" '.[] | select(.tty == $tty) | @json' "$TMPDIR_SCAN/pid_map.json" | head -1)
  if [ -z "$MATCH" ]; then
    log "  ${C_DIM}SKIP${C_RESET}  \"$WS_TITLE\" ${C_DIM}(no opencode process on tty=$TTY)${C_RESET}"
    SKIPPED=$((SKIPPED + 1))
    continue
  fi

  SURFACE_ID=$(echo "$MATCH" | jq -r '.surface')
  WORKSPACE_ID=$(echo "$MATCH" | jq -r '.workspace')
  CWD=$(echo "$MATCH" | jq -r '.cwd')

  # 三级 fallback 匹配
  SESSION_ID=""
  MATCH_LEVEL=""

  # Level 1+2: read-screen
  SCREEN_TITLE=$(extract_screen_title "$WS_REF")
  if [ -n "$SCREEN_TITLE" ]; then
    SESSION_ID=$(match_session_exact "$SCREEN_TITLE")
    [ -n "$SESSION_ID" ] && MATCH_LEVEL="screen"
  fi

  # Level 3: workspace 标题
  if [ -z "$SESSION_ID" ]; then
    SESSION_ID=$(match_session_exact "$WS_SESSION_TITLE")
    [ -n "$SESSION_ID" ] && MATCH_LEVEL="ws-title"
  fi

  # Level 4: 模糊匹配
  if [ -z "$SESSION_ID" ] && [ -n "$SCREEN_TITLE" ]; then
    SESSION_ID=$(match_session_fuzzy "$SCREEN_TITLE")
    [ -n "$SESSION_ID" ] && MATCH_LEVEL="fuzzy-screen"
  fi
  if [ -z "$SESSION_ID" ]; then
    SESSION_ID=$(match_session_fuzzy "$WS_SESSION_TITLE")
    [ -n "$SESSION_ID" ] && MATCH_LEVEL="fuzzy-ws"
  fi

  if [ -z "$SESSION_ID" ]; then
    log "  ${C_RED}MISS${C_RESET}  \"$WS_TITLE\" ${C_DIM}(screen=\"$SCREEN_TITLE\")${C_RESET}"
    SKIPPED=$((SKIPPED + 1))
    continue
  fi

  # 添加到结果 JSON（内存中累积，最后一次性写入）
  RESULT=$(echo "$RESULT" | jq \
    --arg s "$SURFACE_ID" --arg sid "$SESSION_ID" --arg w "$WORKSPACE_ID" --arg c "$CWD" \
    '.[$s] = {sessionId: $sid, workspaceId: $w, cwd: $c}')

  log "  ${C_GREEN}FOUND${C_RESET} \"$WS_TITLE\" → ${C_GREEN}$SESSION_ID${C_RESET} ${C_DIM}($MATCH_LEVEL)${C_RESET}"
  FOUND=$((FOUND + 1))
done

# ── 6. 原子写入：先 tmp 再 mv ──
echo "$RESULT" > "$TMPDIR_SCAN/result.json"
mv "$TMPDIR_SCAN/result.json" "$STATE_FILE"

log ""
if [ "$SKIPPED" -eq 0 ]; then
  log "${C_GREEN}Scan complete: $FOUND session(s) registered.${C_RESET}"
else
  log "${C_YELLOW}Scan complete: $FOUND registered, $SKIPPED skipped.${C_RESET}"
fi
